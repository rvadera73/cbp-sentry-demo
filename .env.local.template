# ===================================
# CBP Sentry — Unified Configuration
# ===================================
# This file works for BOTH local docker-compose AND Cloud Run staging
# Copy to .env.local and adjust for your environment

# === DEPLOYMENT MODE ===
# Options: local, staging, production
DEPLOYMENT_ENV=local

# === API Configuration ===
# For local: use fixture mode (mock external APIs)
# For staging/prod: use live mode (real APIs from Secret Manager)
API_MODE=fixture

# === Database ===
# LOCAL: SQLite file path (auto-seeded)
# STAGING/PROD: PostgreSQL connection string (from Secret Manager)
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=sqlite:///./data/cbp_sentry.db

# === Service-to-Service URLs ===
# LOCAL: Docker network hostnames (sentry-data:8005)
# STAGING/PROD: Cloud Run service URLs (https://sentry-data-xxx.run.app)
DATA_SERVICE_URL=http://sentry-data:8005
SENZING_URL=http://senzing:8250

# === External API Keys ===
# Leave empty for fixture mode, populate for live mode
# All keys should come from Secret Manager in production
VESSELAPI_KEY=
OFAC_API_KEY=
ALTANA_API_KEY=
OPENAI_API_KEY=

# === CORD RAG Configuration ===
# LOCAL: Embedded SQLite at data/cord_rag.db
# STAGING/PROD: Download from Cloud Storage on startup
CORD_DB_PATH=/app/data/cord_rag.db
CORD_GCS_BUCKET=cbp-sentry-data

# === Logging ===
LOG_LEVEL=INFO
PYTHONUNBUFFERED=1

# === Ports (local docker-compose only) ===
UI_PORT=3001
API_PORT=8000
DATA_PORT=8005
SENZING_PORT=8250
