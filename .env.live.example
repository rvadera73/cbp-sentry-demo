# CBP Sentry — Live API Configuration
# Copy this to .env and fill in your API keys

# ========== GLOBAL SETTINGS ==========
API_MODE=live              # live | fixture
FALLBACK_TO_FIXTURE=true   # Fall back to fixtures if API fails

# ========== H1: CORRIDOR RISK ==========

# OpenCorporates API (FREE - no key needed for free tier)
OPENCORPORATES_MODE=live
OPENCORPORATES_ENABLED=true
OPENCORPORATES_API_KEY=          # Optional, leave blank for free tier

# UN Comtrade (FREE - no key needed)
COMTRADE_MODE=live
COMTRADE_ENABLED=true

# ITC Tariffs (FREE - no key needed)
ITC_MODE=live
ITC_ENABLED=true

# ========== H2: VESSEL ANOMALY ==========

# VesselFinder API (REQUIRED - register at https://www.vesselfinder.com/api)
VESSELFINDER_MODE=live
VESSELFINDER_ENABLED=true
VESSELFINDER_API_KEY=your_api_key_here

# AIS Data (OPTIONAL - for enhanced vessel tracking)
AIS_MODE=live
AIS_ENABLED=false
# AIS_API_KEY=your_key_here

# Port Authority Data (FREE - sourced from public databases)
PORT_API_MODE=live
PORT_API_ENABLED=true

# ========== H3: MANIFEST INTELLIGENCE ==========

# OFAC SDN List (FREE - download from Treasury.gov)
OFAC_MODE=live
OFAC_ENABLED=true
OFAC_DATA_PATH=/data/ofac_sdn_list.csv
# Download from: https://www.treasury.gov/ofac/downloads/sdnlist.txt

# Senzing Entity Resolution (EVAL LICENSE - register at https://senzing.com/)
SENZING_MODE=live
SENZING_ENABLED=true
SENZING_API_URL=http://senzing:8250
SENZING_LICENSE_FILE=/etc/senzing/senzing.license

# Altana Atlas ISF Element 9 (COMMERCIAL - not implemented yet)
ALTANA_MODE=fixture
ALTANA_ENABLED=false
# ALTANA_API_KEY=your_key_here    # Will implement after commercial negotiation

# ========== FEEDBACK LOOP SETTINGS ==========
FEEDBACK_LOOP_ENABLED=true
FEEDBACK_APPROVAL_REQUIRED=true
FEEDBACK_RETENTION_DAYS=90

# ========== DATABASE ==========
DATABASE_URL=sqlite:///data/cbp_sentry.db
# Or for production:
# DATABASE_URL=postgresql://user:password@host:5432/cbp_sentry

# ========== LOGGING ==========
LOG_LEVEL=INFO
LOG_FORMAT=json

# ========== MONITORING ==========
METRICS_ENABLED=true
METRICS_PORT=9090
