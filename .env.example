# Environment Configuration
# Copy this to .env and fill in your values

# Deployment
ENVIRONMENT=development
DEBUG=true
DEMO_MODE=true
GCP_PROJECT=cbp-sentry

# Databases
DATABASE_URL=firestore
FIRESTORE_PROJECT=cbp-sentry
NEO4J_URI=neo4j+s://your-aura-instance.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-password

# APIs
SENZING_URL=http://localhost:8250
GEMINI_PROJECT=cbp-sentry
GEMINI_MODEL=gemini-1.5-pro
GOOGLE_API_KEY=your-google-api-key

# Security
MANIFEST_PASSWORD=CBPDemo2026
API_KEY=your-api-key

# Paths
FIXTURES_PATH=./fixtures
MODELS_PATH=./models
SEED_DATA_PATH=./seed_data

# CORS
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# Feature Flags
ENABLE_GRAPH_EXPLORER=true
ENABLE_AI_TRANSPARENCY=true
