# Environment
ENVIRONMENT=development
DEBUG=true

# ── Databases (PostgreSQL — three schemas, each service gets its own URL) ──────
# Local: single sentry-db container, schema isolation via search_path
DATABASE_URL=postgresql://sentry:sentry-secret@localhost:5433/sentry?options=-c%20search_path%3Dcbp_sentry
MLOPS_DATABASE_URL=postgresql://sentry:sentry-secret@localhost:5433/sentry?options=-c%20search_path%3Dmlops
CORD_DATABASE_URL=postgresql://sentry:sentry-secret@localhost:5433/sentry?options=-c%20search_path%3Dcord

# Neon Dev (uncomment and fill to use Neon instead of local PostgreSQL):
# DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/cbp_sentry?sslmode=require
# MLOPS_DATABASE_URL=postgresql://user:pass@ep-yyy.us-east-2.aws.neon.tech/mlops?sslmode=require
# CORD_DATABASE_URL=postgresql://user:pass@ep-zzz.us-east-2.aws.neon.tech/cord?sslmode=require

# API
API_KEY=demo-key
API_VERSION=0.1.0

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# Services
SENZING_URL=http://localhost:8250

# Cloud (cloud-neutral)
GCP_PROJECT=
AWS_REGION=us-east-1

# Observability (OTEL) — local stack at cbp-observability/
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAMESPACE=cbp-sentry

# Demo Mode
DEMO_MODE=true
DEMO_MANIFEST_PATH=
