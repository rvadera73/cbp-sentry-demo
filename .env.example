# Environment
ENVIRONMENT=development
DEBUG=true

# Database
DATABASE_URL=sqlite:///./cbp_sentry.db
NEO4J_URI=neo4j://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password

# API
API_KEY=demo-key
API_VERSION=0.1.0

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# Services
SENZING_URL=http://localhost:8250

# Cloud (cloud-neutral)
GCP_PROJECT=
AWS_REGION=us-east-1

# Demo Mode
DEMO_MODE=true
DEMO_MANIFEST_PATH=
